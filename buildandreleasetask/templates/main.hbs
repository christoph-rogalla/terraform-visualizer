<!DOCTYPE html>
<html lang="en">
{{> head}}
<body>
{{> header}}
<main id="changesContainer">
  {{#if (gt changes.length 0)}}
    {{#each (groupByAction changes)}}
      {{#if (gt this.length 0)}}
        {{> change-section}}
      {{/if}}
    {{/each}}
  {{else}}
    <p>No resource changes were found.</p>
  {{/if}}
</main>
{{> footer}}
</body>
</html>